# Copia este archivo a ".env" y rellena tus propios valores.
# NUNCA subas el archivo ".env" real (con tus credenciales) a GitHub.

# Credenciales de tu app registrada en https://developer.spotify.com/dashboard
SPOTIPY_CLIENT_ID=tu_client_id_aqui
SPOTIPY_CLIENT_SECRET=tu_client_secret_aqui

# Debe coincidir EXACTAMENTE con el Redirect URI configurado en tu app de Spotify.
# Ejemplo típico para desarrollo local:
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8888/callback
